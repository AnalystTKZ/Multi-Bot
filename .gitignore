# Environment files
.env
.env.*
!.env.example
!**/.env.example

# Node
**/node_modules/
**/modules/
**/dist/
**/build/
**/.vite/

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
venv/

# Logs & runtime
**/*.log

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/
.codex/

# Coverage
**/coverage/

# Docker
**/.docker/

# Misc
*.sqlite
*.db

# Build artifacts and junk directories
trading-system/ta-lib/
trading-system/ta-lib-*/
**/.ipynb_checkpoints/
**/*.egg-info/
**/eggs/
**/.eggs/
**/*.dist-info/

# Training data — all raw/processed data excluded (regenerated by pipeline)
trading-system/training_data/

# Processed pipeline outputs (regenerated by pipeline)
trading-system/processed_data/

# ML training datasets (regenerated on Kaggle)
trading-system/ml_training/datasets/

# Model weights — tracked (single source of truth: trading-engine/weights/)
# Backups are tracked so previous weight versions are recoverable from git history

# Runtime logs and journals — tracked (single source of truth: trading-engine/logs/)
# Raw .log text files excluded; structured CSV/JSONL journals are tracked
trading-system/trading-engine/logs/*.log

# Backtesting datasets
trading-system/backtesting/datasets/

# Production env — never commit real secrets
trading-system/.env.production
trading-system/.env

# FAISS vector store — too large for GitHub (100-310 MB)
trading-system/trading-engine/weights/vector_store/
