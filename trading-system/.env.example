INFLUX_PASSWORD=influx_password

# ==================== CACHE & QUEUE ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379/0
RABBITMQ_USER=trading_rabbit
RABBITMQ_PASSWORD=rabbit123
RABBITMQ_URL=amqp://trading_rabbit:rabbit123@rabbitmq:5672

# ==================== BACKEND API ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
PORT=3000
ENV=development
JWT_SECRET=change-me
JWT_EXPIRES_MINUTES=60
JWT_ALGORITHM=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ==================== FRONTEND ====================
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
VITE_APP_NAME=Trading Bot System
VITE_APP_VERSION=1.0.0
VITE_LOG_LEVEL=info
VITE_CHART_THEME=dark
VITE_REFRESH_INTERVAL=5000

# ==================== TRADING ENGINE ====================
TRADING_ENGINE_HOST=0.0.0.0
TRADING_ENGINE_PORT=8000
PAPER_TRADING=true
LOG_LEVEL=INFO
TOTAL_CAPITAL=100000
BROKER_TYPE=mt5
BROKER_API_KEY=
BROKER_SECRET=
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY
NEWS_API_KEY=
NEWS_CALENDAR_URL=
NEWS_CALENDAR_CACHE_MINUTES=15

# ==================== ALERTING ====================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL_USERNAME=
ALERT_EMAIL_PASSWORD=
ALERT_FROM_EMAIL=
ALERT_TO_EMAILS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
WEBHOOK_URL=

# ==================== GRAFANA ====================
GRAFANA_PASSWORD=admin
GRAFANA_ALLOW_SIGNUP=false

# ==================== PROMETHEUS ====================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ==================== ML / AI (feature-flagged) ====================
# Master switch — set true to enable ML signal layer
ML_ENABLED=true

# Ensemble weights (must sum to 1.0)
# ICT_WEIGHT + ML_WEIGHT = 1.0 at baseline; sentiment/anomaly are additive
ML_WEIGHT=0.4
ICT_WEIGHT=0.6

# Minimum ensemble confidence to generate a trade signal (0.0 – 1.0)
ML_CONFIDENCE_THRESHOLD=0.55

# Regime retraining: drop low-confidence rule labels instead of teaching the MLP
# conflicted labels. Raise REGIME_MIN_LABEL_CONFIDENCE for fewer, cleaner samples.
REGIME_DROP_AMBIGUOUS=1
REGIME_MIN_LABEL_CONFIDENCE=0.40
MIN_JOURNAL_STEP7B=50

# ML-native execution gates used by backtests/live signal filtering
ML_DIRECTION_THRESHOLD=0.50
NEUTRAL_BIAS_THRESHOLD=0.50
VOLATILE_ENTRY_THRESHOLD=0.50
PM_MIN_CONFIDENCE=0.50
MAX_DAILY_LOSS_PCT=1.0
MAX_DRAWDOWN_PCT=1.0
MAX_CONCURRENT_POSITIONS=25
COOLDOWN_BARS=1
BLOCK_LTF_CONSOLIDATING=0
REQUIRE_TRENDING_PULLBACK=0
RANGING_REQUIRE_RANGE=0

# Pipeline backtests use raw ML outcomes for Quality/RL sample generation by
# default. Set to 1 for a strict live-risk backtest with the daily kill switch on.
BACKTEST_ENFORCE_DAILY_HALT=0
# Keep sample-generation returns readable by sizing every trade from initial
# capital. Set to 1 only when explicitly testing compounded growth.
BACKTEST_COMPOUND_EQUITY=0

# Redis TTL (seconds) for cached ML scores
ML_CACHE_TTL_SECONDS=60

# Directory containing pre-trained model weight files (relative to trading-engine/)
# Drop .pkl files here to activate trained inference; heuristic mode if empty
ML_MODELS_DIR=models/weights
